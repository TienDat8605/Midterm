  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NpcIntroduction
  speechBubble: {fileID: 0}
  dialogueText: {fileID: 0}
  lines:
  - You found me! I was beginning to think no one would reach the summit.
  - I climbed up to watch the sunrise, but part of the path crumbled behind me.
  - I am safe... though I know Father must be terribly worried.
  - Thank you for crossing the whole mountain to find me, brave little slimes.
  - The climb is over. Let us go home together!
  waitUntilPlayerIsNearby: 1
  triggerDistance: 3
  repeatWhenPlayerReturns: 1
  rearmDistance: 4
  retriggerCooldown: 2
  initialDelay: 0.35
  secondsPerCharacter: 0.035
  pauseBetweenLines: 1.5
  finalDisplayTime: 4
